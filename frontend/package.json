{
  "name": "bank-journal-app-frontend",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron": "electron electron.js",
    "build:web": "expo export --platform web",
    "dist": "node build-desktop.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~55.0.16",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.15",
    "expo-print": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-chart-kit": "^6.12.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1"
  },
  "private": true,
  "build": {
    "appId": "com.weandyou.bankjournal",
    "productName": "Bank Journal",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bank Journal"
    }
  }
}
